<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            x:Class="MechMate.MyRidePage"
            xmlns:models="clr-namespace:MechMate.Models"
            xmlns:pages="clr-namespace:MechMate"
            xmlns:viewmodel="clr-namespace:MechMate.ViewModels"
            x:DataType="viewmodel:MyRidePageViewModel"
            Title="My Ride">
    <VerticalStackLayout>
        <Label Text="{Binding Vehicle.DisplayName}" VerticalOptions="Center" HorizontalOptions="Center" SemanticProperties.HeadingLevel="Level1" />
        <BoxView Margin="10" Grid.ColumnSpan="2" Color="Black" HeightRequest="1"/>
        <Grid Padding="10" ColumnDefinitions="0.5*,0.5,0.5*">
            <Button Grid.Column="0" Text="Export to JSON" SemanticProperties.Hint="Exports vehicle data to JSON" HorizontalOptions="Center" Padding="5" Command="{Binding Source={RelativeSource AncestorType={x:Type pages:MyRidePage}}, Path=BindingContext.SaveJsonFileCommand}" CommandParameter="{Binding .}"/>
            <Label Text="{Binding FileSaverResult}" HorizontalOptions="Center"/>
            <Button Grid.Column="2" Text="Go to My Repairs" SemanticProperties.Hint="Navigates to the My Repair page" HorizontalOptions="Center" Padding="5" Command="{Binding Source={RelativeSource AncestorType={x:Type pages:MyRidePage}}, Path=BindingContext.GoToMyRepairsPageCommand}" CommandParameter="{Binding .}"/>
        </Grid>

        <Image Source="{Binding ImageSource}" HeightRequest="200" Margin="10"/>

        <CollectionView ItemsSource="{Binding DisplayVehicle}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:DisplayItem">
                    <Grid Padding="10" RowDefinitions="Auto, Auto" ColumnDefinitions="0.5*, 0.75*">
                        <Label Grid.Row="0" FontSize="18" Grid.Column="0" Text="{Binding Key}" VerticalOptions="Center" HorizontalOptions="Start"/>
                        <Label Grid.Row="0" FontSize="18" Grid.Column="1" Text="{Binding Value}" VerticalOptions="Center" HorizontalOptions="End"/>
                        <BoxView Grid.Row="1" Grid.ColumnSpan="2" Color="Black" HeightRequest="1"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
